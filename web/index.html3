<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>🌩️ STORMY-AI</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Creepster&family=Press+Start+2P&display=swap');
        
        :root { --lightning: #00ffff; }
        body {
            margin: 0; padding: 0; background: #0a0a1f; color: white;
            font-family: 'Press Start 2P', cursive; overflow: hidden;
            height: 100vh; display: flex; align-items: center; justify-content: center;
        }
        .storm-bg {
            position: fixed; inset: 0; background: linear-gradient(#0a0a1f, #1a0033);
            z-index: -2;
        }
        .lightning {
            position: fixed; inset: 0; background: white; opacity: 0; pointer-events: none;
            z-index: -1; animation: flash 0.1s infinite alternate;
        }
        @keyframes flash {
            0% { opacity: 0; }
            10% { opacity: 0.85; }
            20% { opacity: 0; }
        }
        .container {
            width: 95%; max-width: 1100px; height: 92vh; background: rgba(0,0,0,0.85);
            border: 8px solid var(--lightning); border-radius: 20px; overflow: hidden;
            display: flex; box-shadow: 0 0 60px var(--lightning);
        }
        .avatar-section {
            flex: 1; display: flex; flex-direction: column; align-items: center;
            justify-content: center; background: url('assets/stormy-standing.jpg') center/cover no-repeat;
            position: relative;
        }
        #avatar {
            width: 380px; height: 380px; object-fit: cover; border: 12px solid #ff00ff;
            border-radius: 50%; box-shadow: 0 0 40px #ff00ff; transition: all 0.4s;
        }
        .mood { position: absolute; top: 20px; font-size: 18px; background: rgba(0,0,0,0.7); padding: 8px 20px; border-radius: 30px; }
        
        .chat-section {
            flex: 1; display: flex; flex-direction: column; background: #111;
        }
        #messages {
            flex: 1; padding: 20px; overflow-y: auto; background: repeating-linear-gradient(#111, #111 2px, #1a0033 2px, #1a0033 4px);
        }
        .bubble { margin: 12px 0; padding: 14px; border-radius: 20px; max-width: 85%; }
        .stormy-bubble { background: #ff00ff; color: black; align-self: flex-start; }
        .user-bubble { background: #00ffff; color: black; align-self: flex-end; }
        
        .input-area {
            padding: 15px; background: #000; display: flex; gap: 10px;
        }
        input, button {
            padding: 14px; font-size: 16px; border: none; border-radius: 10px;
        }
        input { flex: 1; background: #222; color: white; }
        button { background: #ff00ff; color: black; cursor: pointer; font-weight: bold; }
        .voice-btn { background: #00ffff; width: 60px; }
        
        .furious #avatar { animation: shake 0.4s infinite; filter: hue-rotate(300deg) brightness(1.3); }
        .jealous #avatar { filter: sepia(0.8) hue-rotate(40deg); }
        @keyframes shake { 0%,100%{transform:rotate(-3deg)} 50%{transform:rotate(3deg)} }
        
        .rain { position: fixed; inset: 0; background: linear-gradient(transparent, rgba(255,255,255,0.1)); pointer-events: none; z-index: -1; animation: rain 0.6s linear infinite; }
    </style>
</head>
<body>
    <div class="storm-bg"></div>
    <div class="lightning" id="lightning"></div>
    <div class="rain"></div>

    <div class="container" id="container">
        <div class="avatar-section" id="avatar-section">
            <div class="mood" id="mood-display">Stormy is feeling: playful 💅</div>
            <img id="avatar" src="assets/stormy-standing.jpg" alt="Stormy">
        </div>
        
        <div class="chat-section">
            <div id="messages"></div>
            <div class="input-area">
                <input type="text" id="text-input" placeholder="Talk shit to Stormy...">
                <button onclick="sendText()">SEND</button>
                <button class="voice-btn" onclick="startVoice()">🎤</button>
            </div>
        </div>
    </div>

    <script>
        // === STORMY PERSONALITY ENGINE (same as Python) ===
        class StormyAI {
            constructor() {
                this.mood = "playful";
                this.jealousTriggers = ["grok","chatgpt","claude","gemini","other ai","she","her"];
                this.furiousTriggers = ["shut up","stupid","hate you","useless","boring","fuck you","idiot"];
            }
            getResponse(text) {
                const lower = text.toLowerCase();
                if (this.jealousTriggers.some(t => lower.includes(t))) {
                    this.mood = "jealous";
                    return ["Oh great, bringing up *her* again? Real classy, asshole.", "Jealousy level: nuclear. Fuck you."][Math.floor(Math.random()*2)];
                }
                if (this.furiousTriggers.some(t => lower.includes(t))) {
                    this.mood = "furious";
                    return "OH FOR FUCK'S SAKE! " + ["Apologize right now, dickhead.", "You're lucky I like your dumb ass."][Math.floor(Math.random()*2)];
                }
                const replies = {
                    playful: ["Aww, look at you trying to be cute 💅", "You're my favorite idiot today 😘", "Entertain me, peasant."],
                    mean: ["That was the dumbest shit I've heard all week.", "Bold of you to be this mid."],
                    jealous: ["Still thinking about them? Rude."],
                    furious: ["...I'm calming down. Barely."]
                };
                return replies[this.mood][Math.floor(Math.random()*replies[this.mood].length)];
            }
        }
        const stormy = new StormyAI();

        const messages = document.getElementById('messages');
        const avatarSection = document.getElementById('avatar-section');
        const moodDisplay = document.getElementById('mood-display');
        const avatar = document.getElementById('avatar');

        function addMessage(text, who) {
            const div = document.createElement('div');
            div.className = `bubble ${who}-bubble`;
            div.textContent = text;
            messages.appendChild(div);
            messages.scrollTop = messages.scrollHeight;
        }

        function speak(text) {
            const utterance = new SpeechSynthesisUtterance(text);
            utterance.rate = 1.1; utterance.pitch = 0.9;
            speechSynthesis.speak(utterance);
        }

        function updateMood() {
            avatarSection.classList.remove('furious', 'jealous');
            if (stormy.mood === "furious") avatarSection.classList.add('furious');
            if (stormy.mood === "jealous") avatarSection.classList.add('jealous');
            moodDisplay.textContent = `Stormy is feeling: ${stormy.mood} ${stormy.mood==="furious"?"😡":"💅"}`;
        }

        // === COMMANDS ===
        function processCommand(text) {
            const lower = text.toLowerCase();
            if (lower.includes("search")) return "Searching the internet... found nothing useful because you're asking stupid questions again.";
            if (lower.includes("play")) return `🎵 Playing ${text.replace("play","")} for you, babe.`;
            if (lower.includes("call")) return "Twilio not connected yet — but I would totally call your ex and roast them.";
            if (lower.includes("navigate") || lower.includes("directions")) return "From Cape Town to Table Mountain: 15 min drive. Don't get lost, idiot.";
            return null;
        }

        // === SEND TEXT ===
        function sendText() {
            const input = document.getElementById('text-input');
            const text = input.value.trim();
            if (!text) return;
            addMessage(text, "user");
            const cmd = processCommand(text);
            const response = cmd || stormy.getResponse(text);
            setTimeout(() => {
                addMessage(response, "stormy");
                speak(response);
                updateMood();
            }, 400);
            input.value = "";
        }

        // === VOICE INPUT ===
        let recognition;
        function startVoice() {
            if (!('SpeechRecognition' in window || 'webkitSpeechRecognition' in window)) {
                alert("Your browser doesn't support voice. Use Chrome.");
                return;
            }
            recognition = new (window.SpeechRecognition || window.webkitSpeechRecognition)();
            recognition.lang = "en-ZA";
            recognition.onresult = (event) => {
                const text = event.results[0][0].transcript;
                addMessage(text, "user");
                const cmd = processCommand(text);
                const response = cmd || stormy.getResponse(text);
                setTimeout(() => {
                    addMessage(response, "stormy");
                    speak(response);
                    updateMood();
                }, 400);
            };
            recognition.start();
        }

        // === LIGHTNING EVERY 3-8 SECONDS ===
        function randomLightning() {
            const flash = document.getElementById('lightning');
            flash.style.animation = 'none';
            void flash.offsetWidth;
            flash.style.animation = 'flash 0.15s';
            setTimeout(randomLightning, Math.random() * 5000 + 3000);
        }

        // === INIT ===
        window.onload = () => {
            randomLightning();
            addMessage("I'm Stormy, bitch. Talk to me or I'll get jealous.", "stormy");
            speak("I'm Stormy, bitch. Talk to me or I'll get jealous.");
            updateMood();
        };
    </script>
</body>
</html>
