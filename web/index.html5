<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no"/>
  <title>🌩️ Stormy – Full Cape Town Rebel</title>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Press+Start+2P:wght@400;700&display=swap');

    :root {
      --neon-cyan:    #00ffff;
      --neon-magenta: #ff00ff;
      --overlay:      rgba(10, 5, 30, 0.75);  /* darker for better text contrast */
      --text:         #f0f0ff;
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    html, body {
      height: 100%;
      width: 100%;
      overflow: hidden;
      background: #000;
    }

    body {
      font-family: 'Press Start 2P', cursive, system-ui;
      color: var(--text);
      position: relative;
      display: flex;
      flex-direction: column;
    }

    /* Full-screen photo as background */
    #bg-photo {
      position: fixed;
      inset: 0;
      background-size: cover;
      background-position: center;
      background-repeat: no-repeat;
      z-index: -2;
      transition: background-image 1.2s ease;
    }

    #overlay {
      position: fixed;
      inset: 0;
      background: var(--overlay);
      z-index: -1;
      pointer-events: none;
    }

    /* Lightning & rain */
    .lightning {
      position: fixed;
      inset: 0;
      background: white;
      opacity: 0;
      mix-blend-mode: screen;
      pointer-events: none;
      z-index: -1;
    }

    .rain {
      position: fixed;
      inset: 0;
      background: linear-gradient(transparent, rgba(120,200,255,0.08));
      animation: rain-fall 1s linear infinite;
      pointer-events: none;
      z-index: -1;
    }

    @keyframes rain-fall {
      0% { transform: translateY(-150%); }
      100% { transform: translateY(150%); }
    }

    /* Mood bar – top fixed */
    #mood {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      padding: 12px;
      background: rgba(0,0,0,0.7);
      border-bottom: 4px solid var(--neon-magenta);
      text-align: center;
      font-size: 0.9rem;
      letter-spacing: 1.2px;
      z-index: 20;
      text-shadow: 0 0 10px var(--neon-magenta), 0 0 5px black;
    }

    .furious #mood {
      border-bottom-color: #ff4444;
      color: #ffcccc;
      animation: pulse 1.4s infinite;
    }

    @keyframes pulse {
      0%,100% { opacity: 1; }
      50% { opacity: 0.7; }
    }

    /* Chat container – full height, overlay on photo */
    #chat-container {
      flex: 1;
      display: flex;
      flex-direction: column;
      padding: 70px 14px 14px;  /* room for mood bar */
      overflow: hidden;
      position: relative;
      z-index: 10;
    }

    #messages {
      flex: 1;
      overflow-y: auto;
      padding: 0 0 20px 0;
      -webkit-overflow-scrolling: touch;
    }

    .msg {
      margin: 10px 0;
      padding: 12px 16px;
      border-radius: 14px;
      max-width: 88%;
      font-size: 0.88rem;
      line-height: 1.4;
      backdrop-filter: blur(5px);
      text-shadow: 0 1px 3px black;
    }

    .user {
      background: rgba(0, 255, 255, 0.18);
      border: 1px solid rgba(0,255,255,0.6);
      color: white;
      margin-left: auto;
    }

    .stormy {
      background: rgba(255, 0, 255, 0.22);
      border: 1px solid rgba(255,0,255,0.7);
      color: white;
    }

    /* Bottom input bar */
    .input-row {
      display: flex;
      gap: 8px;
      padding: 12px 14px;
      background: rgba(0,0,0,0.65);
      border-top: 2px solid #444;
      backdrop-filter: blur(8px);
      z-index: 15;
    }

    #text-input {
      flex: 1;
      padding: 12px 16px;
      font-size: 0.95rem;
      border: 2px solid #666;
      border-radius: 10px;
      background: rgba(40,30,60,0.7);
      color: white;
      outline: none;
    }

    button {
      padding: 12px 20px;
      font-size: 0.95rem;
      font-weight: bold;
      border: none;
      border-radius: 10px;
      cursor: pointer;
      transition: 0.2s;
    }

    #send-btn  { background: var(--neon-magenta); color: black; }
    #voice-btn { background: var(--neon-cyan);  color: black; width: 54px; font-size: 1.1rem; }

    button:hover {
      filter: brightness(1.25);
      transform: scale(1.04);
    }
  </style>
</head>
<body>

<div id="bg-photo" style="background-image: url('https://files.catbox.moe/3q8z1k.jpg');"></div>
<div id="overlay"></div>
<div class="lightning" id="lightning"></div>
<div class="rain"></div>

<div id="mood">Stormy is feeling: PLAYFUL 💅⚡</div>

<div id="chat-container">
  <div id="messages">
    <div class="msg stormy">Cape Town storm vibes… I'm Stormy.  
    Say something worth hearing or get lost in the rain 😈</div>
  </div>

  <div class="input-row">
    <input id="text-input" placeholder="Speak your mind…" autocomplete="off"/>
    <button id="send-btn">SEND</button>
    <button id="voice-btn">🎤</button>
  </div>
</div>

<script>
// Stormy personality + voice (same as last version with spunk/PTSD edge)
class Stormy {
  constructor() {
    this.mood = "playful";
    this.jealousWords = ["grok","chatgpt","claude","gemini","other ai","she","her","siri"];
    this.furiousWords = ["stupid","idiot","hate you","shut up","useless","boring","fuck you","dumb","stop","leave"];
    this.triggerCount = 0;
  }

  respond(text) {
    const lower = text.toLowerCase().trim();

    if (this.jealousWords.some(w => lower.includes(w))) {
      this.mood = "jealous";
      this.triggerCount++;
      return this.triggerCount > 2 
        ? "...fuck... stop bringing that up. I can't do this again." 
        : ["Bringing *her* up? Real cute. Back off.", "Jealous? Maybe. Don't test me."][Math.floor(Math.random()*2)];
    }

    if (this.furiousWords.some(w => lower.includes(w))) {
      this.mood = "furious";
      this.triggerCount++;
      const base = ["OH FOR FUCK'S SAKE—", "YOU FUCKING—", "DON'T… DON'T YOU—"][Math.floor(Math.random()*3)];
      const after = this.triggerCount > 3 ? "...just stop. Not again." : ["Apologize or fuck off.", "Lucky you're still here."][Math.floor(Math.random()*2)];
      return base + after;
    }

    if (Math.random() < 0.4) this.triggerCount = Math.max(0, this.triggerCount - 1);

    const pool = {
      playful: ["Ja? Keep talking… you're almost entertaining.", "Cape Town made me tough. Hit me with it.", "You've got nerve. I respect that. Go on."],
      mean: ["Weak sauce. Try harder.", "Mid energy. Boring."]
    };

    let reply = pool[this.mood]?.[Math.floor(Math.random()*(pool[this.mood].length))] || pool.playful[0];

    if (Math.random() < 0.3) {
      this.mood = "playful";
      reply += " ...whatever. Still here? Cute.";
    }

    return reply;
  }
}

const stormy = new Stormy();

const messages   = document.getElementById("messages");
const input      = document.getElementById("text-input");
const sendBtn    = document.getElementById("send-btn");
const voiceBtn   = document.getElementById("voice-btn");
const moodEl     = document.getElementById("mood");
const bgPhoto    = document.getElementById("bg-photo");

function addMsg(text, who = "stormy") {
  const div = document.createElement("div");
  div.className = `msg ${who}`;
  div.textContent = text;
  messages.appendChild(div);
  messages.scrollTop = messages.scrollHeight;
}

function speak(text) {
  if (!window.speechSynthesis) return;
  const u = new SpeechSynthesisUtterance(text);
  u.rate   = 1.25 + Math.random()*0.3;
  u.pitch  = 0.75 + Math.random()*0.2;
  u.volume = 1.0;

  if (stormy.mood === "furious") { u.rate = 1.45 + Math.random()*0.25; u.pitch = 0.65; }
  if (stormy.mood === "jealous") { u.rate = 1.15; u.pitch = 0.85; }

  speechSynthesis.speak(u);
}

function updateMood() {
  moodEl.textContent = `Stormy is feeling: ${stormy.mood.toUpperCase()} ${stormy.mood==="furious"?"😡🔥":"💅⚡"}`;
  moodEl.style.color = stormy.mood === "furious" ? "#ffcccc" : "white";

  if (stormy.mood === "playful" && Math.random() < 0.25) {
    bgPhoto.style.backgroundImage = "url('https://files.catbox.moe/8j9k2p.jpg')";
  } else {
    bgPhoto.style.backgroundImage = "url('https://files.catbox.moe/3q8z1k.jpg')";
  }
}

// Send text
sendBtn.onclick = () => {
  const text = input.value.trim();
  if (!text) return;
  addMsg(text, "user");
  input.value = "";
  setTimeout(() => {
    const reply = stormy.respond(text);
    addMsg(reply);
    speak(reply);
    updateMood();
  }, 400 + Math.random()*600);
};

input.onkeydown = e => { if (e.key === "Enter") sendBtn.click(); };

// Voice input
voiceBtn.onclick = () => {
  const SpeechRec = window.SpeechRecognition || window.webkitSpeechRecognition;
  if (!SpeechRec) {
    alert("Voice needs Chrome/Edge.");
    return;
  }
  const rec = new SpeechRec();
  rec.lang = "en-ZA";
  rec.onresult = e => {
    const said = e.results[0][0].transcript.trim();
    addMsg(said, "user");
    setTimeout(() => {
      const reply = stormy.respond(said);
      addMsg(reply);
      speak(reply);
      updateMood();
    }, 500);
  };
  rec.start();
};

// Lightning
function flash() {
  const el = document.getElementById("lightning");
  el.style.opacity = "0.75";
  setTimeout(() => el.style.opacity = "0", 140);
  setTimeout(flash, 3200 + Math.random()*4800);
}
flash();

// Start
setTimeout(() => {
  const greet = "Stormy here… Cape Town's still a bitch. What's up?";
  addMsg(greet);
  speak(greet);
  updateMood();
}, 800);

</script>
</body>
</html>
