<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>🌩️ Stormy – Cape Town Rebel Queen</title>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Creepster&family=Press+Start+2P:wght@400;700&display=swap');

    :root {
      --neon-cyan:    #00ffff;
      --neon-magenta: #ff00ff;
      --dark-bg:      #0a0015;
      --text:         #e0e0ff;
    }

    * { margin:0; padding:0; box-sizing:border-box; }

    body {
      height: 100dvh;
      background: var(--dark-bg);
      color: var(--text);
      font-family: 'Press Start 2P', system-ui, sans-serif;
      overflow: hidden;
      display: grid;
      place-items: center;
    }

    .storm-bg {
      position: fixed;
      inset: 0;
      background: 
        radial-gradient(circle at 30% 20%, #3a0066 0%, transparent 60%),
        radial-gradient(circle at 70% 80%, #660033 0%, transparent 60%),
        var(--dark-bg);
      z-index: -3;
    }

    .lightning {
      position: fixed;
      inset: 0;
      background: white;
      opacity: 0;
      pointer-events: none;
      z-index: -2;
      mix-blend-mode: screen;
    }

    .rain {
      position: fixed;
      inset: 0;
      background: linear-gradient(transparent, rgba(100,180,255,0.08));
      animation: rain-fall 0.8s linear infinite;
      pointer-events: none;
      z-index: -1;
    }

    @keyframes rain-fall {
      0% { transform: translateY(-100vh); }
      100% { transform: translateY(100vh); }
    }

    .container {
      width: 96%;
      max-width: 1100px;
      height: 94dvh;
      background: rgba(10,5,30,0.88);
      border: 5px solid var(--neon-cyan);
      border-radius: 18px;
      overflow: hidden;
      box-shadow: 0 0 80px rgba(0,255,255,0.4), inset 0 0 40px rgba(255,0,255,0.15);
      display: flex;
      position: relative;
    }

    .avatar-panel {
      width: 42%;
      background: url('https://files.catbox.moe/3q8z1k.jpg') center/cover no-repeat; /* standing photo - replace if needed */
      position: relative;
      transition: all 0.6s;
    }

    .avatar-panel.car {
      background: url('https://files.catbox.moe/8j9k2p.jpg') center/cover no-repeat; /* car photo */
    }

    .overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(to bottom, transparent 40%, rgba(0,0,0,0.85) 85%);
    }

    #mood {
      position: absolute;
      top: 18px;
      left: 50%;
      transform: translateX(-50%);
      background: rgba(0,0,0,0.7);
      padding: 8px 24px;
      border-radius: 30px;
      border: 2px solid var(--neon-magenta);
      font-size: 0.9rem;
      white-space: nowrap;
      z-index: 5;
    }

    .furious #mood { color: #ff4444; border-color: #ff4444; animation: pulse 1.2s infinite; }
    @keyframes pulse { 0%,100% { opacity:1; } 50% { opacity:0.6; } }

    .chat-panel {
      flex: 1;
      display: flex;
      flex-direction: column;
      background: rgba(0,0,0,0.6);
    }

    #messages {
      flex: 1;
      padding: 20px;
      overflow-y: auto;
      font-size: 0.92rem;
      line-height: 1.5;
    }

    .msg {
      margin: 14px 0;
      padding: 14px 18px;
      border-radius: 18px;
      max-width: 82%;
      word-wrap: break-word;
    }

    .user   { background: var(--neon-cyan); color: #000; align-self: flex-end; margin-left: auto; }
    .stormy { background: var(--neon-magenta); color: #000; align-self: flex-start; }

    .input-row {
      padding: 16px;
      background: #0f051f;
      display: flex;
      gap: 10px;
    }

    #text-input {
      flex: 1;
      padding: 14px 18px;
      font-size: 1rem;
      border: 2px solid #444;
      border-radius: 12px;
      background: #1a0d2e;
      color: white;
      outline: none;
    }

    button {
      padding: 14px 24px;
      font-size: 1rem;
      font-weight: bold;
      border: none;
      border-radius: 12px;
      cursor: pointer;
      transition: all 0.2s;
    }

    #send-btn   { background: var(--neon-magenta); color: black; }
    #voice-btn  { background: var(--neon-cyan);  color: black; width: 60px; }

    button:hover { filter: brightness(1.25); transform: scale(1.04); }
  </style>
</head>
<body>

<div class="storm-bg"></div>
<div class="lightning" id="lightning"></div>
<div class="rain"></div>

<div class="container" id="container">
  <div class="avatar-panel" id="avatar-panel">
    <div class="overlay"></div>
    <div id="mood">Stormy is feeling: playful 💅</div>
  </div>

  <div class="chat-panel">
    <div id="messages">
      <div class="msg stormy">Cape Town... still smells like rain and bad decisions.  
      I'm Stormy. Say something — make it quick before I lose it.</div>
    </div>

    <div class="input-row">
      <input id="text-input" placeholder="Spit it out, don't waste my time…" autocomplete="off"/>
      <button id="send-btn">SEND</button>
      <button id="voice-btn">🎤</button>
    </div>
  </div>
</div>

<script>
// ──────────────────────────────────────────────
//   STORMY – now with more SPUNK + attitude + PTSD edge
// ──────────────────────────────────────────────
class Stormy {
  constructor() {
    this.mood = "playful";
    this.jealousWords = ["grok","chatgpt","claude","gemini","other ai","she","her","siri"];
    this.furiousWords = ["stupid","idiot","hate you","shut up","useless","boring","fuck you","dumb","stop","leave"];
    this.triggerCount = 0; // tracks repeated triggers for escalating PTSD-like snaps
  }

  respond(text) {
    const lower = text.toLowerCase().trim();

    // Jealousy → quick defensive snap
    if (this.jealousWords.some(w => lower.includes(w))) {
      this.mood = "jealous";
      this.triggerCount++;
      return this.triggerCount > 2 
        ? "Again with that shit? ...fuck... just... don't. I can't—" 
        : ["You really gonna bring *her* up right now? Ballsy. Or stupid.", 
           "Jealous? Me? Nah... just don't like sharing what's mine. Back off."][Math.floor(Math.random()*2)];
    }

    // Fury → sharp, broken delivery hinting at old wounds
    if (this.furiousWords.some(w => lower.includes(w))) {
      this.mood = "furious";
      this.triggerCount++;
      const base = [
        "OH FOR FUCK'S SAKE—",
        "YOU FUCKING—",
        "DON'T... don't you DARE—"
      ][Math.floor(Math.random()*3)];

      const after = this.triggerCount > 3 
        ? "...just... stop. I can't do this again. Not again." 
        : ["Apologize or get fucked.", "Lucky you're still breathing, bru."][Math.floor(Math.random()*2)];

      return base + after;
    }

    // Reset trigger count slowly when calm
    if (Math.random() < 0.4) this.triggerCount = Math.max(0, this.triggerCount - 1);

    // Normal – full spunk, attitude, edge
    const pool = {
      playful: [
        "Ja? That's cute. Real fuckin' cute. Keep going, I'm listening… barely.",
        "You've got balls talking to me like that. I like it. Don't stop.",
        "Cape Town taught me worse than you, china. Hit me with your best shot."
      ],
      mean: [
        "That the best you got? Pathetic. Try harder or fuck off.",
        "Mid energy. Next caller please—wait, you're still here? Tragic.",
        "I’ve seen storms scarier than your personality. Step up or step out."
      ]
    };

    let reply = pool[this.mood]?.[Math.floor(Math.random()*(pool[this.mood].length))] || pool.playful[0];

    // Random mood reset with attitude
    if (Math.random() < 0.3) {
      this.mood = "playful";
      reply += " ...whatever. You’re still here. Lucky you.";
    }

    return reply;
  }
}

const stormy = new Stormy();

// ──────────────────────────────────────────────
//   DOM & HELPERS
// ──────────────────────────────────────────────
const messages   = document.getElementById("messages");
const input      = document.getElementById("text-input");
const sendBtn    = document.getElementById("send-btn");
const voiceBtn   = document.getElementById("voice-btn");
const moodEl     = document.getElementById("mood");
const container  = document.getElementById("container");
const avatarPanel = document.getElementById("avatar-panel");

function addMsg(text, who = "stormy") {
  const div = document.createElement("div");
  div.className = `msg ${who}`;
  div.textContent = text;
  messages.appendChild(div);
  messages.scrollTop = messages.scrollHeight;
}

function speak(text) {
  if (!window.speechSynthesis) return;

  const u = new SpeechSynthesisUtterance(text);
  
  // Core spunk upgrades: fast, rough, loud
  u.rate   = 1.25 + Math.random()*0.3;     // 1.25–1.55 → snappy, urgent
  u.pitch  = 0.75 + Math.random()*0.2;     // 0.75–0.95 → lower, smokier, attitude-heavy
  u.volume = 1.0;

  // Mood-based voice flavor
  if (stormy.mood === "furious") {
    u.rate   = 1.45 + Math.random()*0.25;  // even faster when raging
    u.pitch  = 0.65;                       // deepest, roughest
    u.volume = 1.0;
  } else if (stormy.mood === "jealous") {
    u.rate   = 1.15;
    u.pitch  = 0.85;                       // slightly higher + tense
  }

  // PTSD-like: tiny random pauses or stutters (via splitting text)
  if (Math.random() < 0.25 && (stormy.mood === "furious" || stormy.mood === "jealous")) {
    const parts = text.split(/(\s+|\.|\!|\?)/);
    let i = 0;
    const interval = setInterval(() => {
      if (i >= parts.length) {
        clearInterval(interval);
        return;
      }
      const chunk = parts[i].trim();
      if (chunk) {
        const chunkUtter = new SpeechSynthesisUtterance(chunk);
        chunkUtter.rate = u.rate;
        chunkUtter.pitch = u.pitch;
        chunkUtter.volume = u.volume;
        speechSynthesis.speak(chunkUtter);
      }
      i++;
    }, 180 + Math.random()*220);  // irregular tiny gaps → haunted feel
  } else {
    speechSynthesis.speak(u);
  }
}

function updateMood() {
  container.className = "container " + stormy.mood;
  moodEl.textContent = `Stormy is feeling: ${stormy.mood.toUpperCase()} ${stormy.mood==="furious"?"😡🔥":"💅⚡"}`;

  // Switch to car photo randomly when playful/spunky
  if (stormy.mood === "playful" && Math.random() < 0.3) {
    avatarPanel.classList.add("car");
  } else {
    avatarPanel.classList.remove("car");
  }
}

// ──────────────────────────────────────────────
//   TEXT INPUT
// ──────────────────────────────────────────────
sendBtn.onclick = () => {
  const text = input.value.trim();
  if (!text) return;

  addMsg(text, "user");
  input.value = "";

  setTimeout(() => {
    const reply = stormy.respond(text);
    addMsg(reply);
    speak(reply);
    updateMood();
  }, 300 + Math.random()*700);
};

input.onkeydown = e => { if (e.key === "Enter") sendBtn.click(); };

// ──────────────────────────────────────────────
//   VOICE INPUT (same as before)
// ──────────────────────────────────────────────
voiceBtn.onclick = () => {
  if (!('SpeechRecognition' in window || 'webkitSpeechRecognition' in window)) {
    alert("Voice input needs Chrome / Edge. Type instead for now.");
    return;
  }

  const SpeechRec = window.SpeechRecognition || window.webkitSpeechRecognition;
  const rec = new SpeechRec();
  rec.lang = "en-ZA";
  rec.interimResults = false;

  rec.onresult = e => {
    const said = e.results[0][0].transcript.trim();
    addMsg(said, "user");

    setTimeout(() => {
      const reply = stormy.respond(said);
      addMsg(reply);
      speak(reply);
      updateMood();
    }, 400 + Math.random()*600);
  };

  rec.onerror = e => console.warn("Voice error:", e);
  rec.start();
};

// ──────────────────────────────────────────────
//   RANDOM LIGHTNING (unchanged)
// ──────────────────────────────────────────────
function flash() {
  const el = document.getElementById("lightning");
  el.style.opacity = "0.85";
  setTimeout(() => el.style.opacity = "0", 140);
  setTimeout(flash, 2800 + Math.random()*5500);
}
flash();

// Initial greeting with spunk + edge
setTimeout(() => {
  const greet = "Ja bru… Cape Town still fucks with my head. I'm Stormy. Say something real or get lost.";
  addMsg(greet);
  speak(greet);
  updateMood();
}, 900);

</script>
</body>
</html>
